{
    "compilerOptions": {
        "baseUrl": ".",
        "ignoreDeprecations": "6.0",
        "paths": {
            "#root": ["./src/index.ts"],
            "#core": ["./src/core/index.ts"],
            "#elgamal": ["./src/elgamal/index.ts"],
            "#unsafe": ["./src/unsafe/index.ts"],
            "#serialize": ["./src/serialize/index.ts"]
        },
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "removeComments": true,
        "declaration": false,
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "strict": true,
        "sourceMap": true,
        "allowJs": true,
        "noEmit": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "noUnusedParameters": true,
        "noUnusedLocals": true
    },
    "include": [
        "src/**/*",
        "scripts/**/*",
        "test-vectors/**/*",
        "tests/**/*",
        "vitest.config.ts",
        "eslint.config.js",
        "typedoc.config.mjs"
    ]
}
