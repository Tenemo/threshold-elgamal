{
    "compilerOptions": {
        "baseUrl": ".",
        "ignoreDeprecations": "6.0",
        "paths": {
            "threshold-elgamal": ["./src/index.ts"],
            "threshold-elgamal/core": ["./src/core/index.ts"],
            "threshold-elgamal/elgamal": ["./src/elgamal/index.ts"],
            "threshold-elgamal/serialize": ["./src/serialize/index.ts"]
        },
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "removeComments": true,
        "declaration": false,
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "strict": true,
        "sourceMap": true,
        "allowJs": true,
        "noEmit": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "noUnusedParameters": true,
        "noUnusedLocals": true
    },
    "include": [
        "src/**/*",
        "tests/**/*",
        "vitest.config.ts",
        "eslint.config.js"
    ]
}
