---
import { Card, LinkButton } from '@astrojs/starlight/components';

interface Props {
    bullets: string[];
    cta: string;
    description: string;
    href: string;
    title: string;
}

const { bullets, cta, description, href, title } = Astro.props;
---

<Card title={title}>
    <div class="landing-card-body">
        <div class="landing-card-copy">
            <p>{description}</p>
            <ul>
                {
                    bullets.map((bullet) => (
                        <li>{bullet}</li>
                    ))
                }
            </ul>
        </div>
        <div class="landing-card-actions">
            <LinkButton href={href} variant="secondary">
                {cta}
            </LinkButton>
        </div>
    </div>
</Card>
