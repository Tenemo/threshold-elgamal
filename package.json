{
    "name": "threshold-elgamal",
    "version": "1.0.0-beta.0",
    "description": "A browser-native TypeScript ElGamal library for bigint-based research prototypes, shipping additive ElGamal, dealer threshold decryption, VSS, proofs, protocol helpers, transport primitives, and log-driven DKG state machines.",
    "author": "Piotr Piech <piotr@piech.dev>",
    "license": "MPL-2.0",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "imports": {
        "#root": "./src/index.ts",
        "#core": "./src/core/index.ts",
        "#dkg": "./src/dkg/index.ts",
        "#elgamal": "./src/elgamal/index.ts",
        "#proofs": "./src/proofs/index.ts",
        "#protocol": "./src/protocol/index.ts",
        "#runtime": "./src/runtime/index.ts",
        "#threshold": "./src/threshold/index.ts",
        "#transport": "./src/transport/index.ts",
        "#transport-advanced": "./src/transport/advanced.ts",
        "#vss": "./src/vss/index.ts",
        "#serialize": "./src/serialize/index.ts"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./core": {
            "types": "./dist/core/index.d.ts",
            "import": "./dist/core/index.js"
        },
        "./elgamal": {
            "types": "./dist/elgamal/index.d.ts",
            "import": "./dist/elgamal/index.js"
        },
        "./dkg": {
            "types": "./dist/dkg/index.d.ts",
            "import": "./dist/dkg/index.js"
        },
        "./proofs": {
            "types": "./dist/proofs/index.d.ts",
            "import": "./dist/proofs/index.js"
        },
        "./protocol": {
            "types": "./dist/protocol/index.d.ts",
            "import": "./dist/protocol/index.js"
        },
        "./runtime": {
            "types": "./dist/runtime/index.d.ts",
            "import": "./dist/runtime/index.js"
        },
        "./threshold": {
            "types": "./dist/threshold/index.d.ts",
            "import": "./dist/threshold/index.js"
        },
        "./transport": {
            "types": "./dist/transport/index.d.ts",
            "import": "./dist/transport/index.js"
        },
        "./transport/advanced": {
            "types": "./dist/transport/advanced.d.ts",
            "import": "./dist/transport/advanced.js"
        },
        "./vss": {
            "types": "./dist/vss/index.d.ts",
            "import": "./dist/vss/index.js"
        },
        "./serialize": {
            "types": "./dist/serialize/index.d.ts",
            "import": "./dist/serialize/index.js"
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Tenemo/threshold-elgamal.git"
    },
    "bugs": {
        "url": "https://github.com/Tenemo/threshold-elgamal/issues"
    },
    "homepage": "https://tenemo.github.io/threshold-elgamal/",
    "packageManager": "pnpm@10.33.0",
    "scripts": {
        "lint": "eslint . -c eslint.config.js",
        "eslint": "pnpm run lint",
        "eslint:fix": "eslint . --fix -c eslint.config.js",
        "typecheck": "tsc",
        "tsc": "pnpm run typecheck",
        "guard:no-math-random": "tsx ./tests/guards/check-no-math-random.ts",
        "verify:h-derivation": "tsx ./tools/verify-h-derivation.ts",
        "vectors:threshold": "tsx ./tools/generate-threshold-vectors.ts",
        "vectors:protocol": "tsx ./tools/generate-protocol-vectors.ts",
        "bench:micro": "tsx ./tools/benchmarks/microbench.ts",
        "bench:dkg": "tsx ./tools/benchmarks/dkg-benchmark.ts",
        "check": "pnpm run lint && pnpm run typecheck && pnpm run guard:no-math-random && pnpm run verify:h-derivation && pnpm run test",
        "prebuild": "pnpm run check && pnpm exec del-cli dist",
        "build": "tsc --project tsconfig.build.json",
        "build:skip": "pnpm exec del-cli dist && tsc --project tsconfig.build.json",
        "test:node": "vitest --project node --run",
        "test:browser": "vitest --project browser --run",
        "test": "pnpm run test:node && pnpm run test:browser",
        "test:watch": "vitest --project node --watch",
        "coverage:node": "vitest --project node --run --coverage",
        "coverage:badge": "pnpm run coverage:node && tsx ./tools/generate-coverage-badge.ts",
        "ci": "pnpm run check && pnpm run build:skip && pnpm run verify:docs && pnpm run docs:build:site",
        "docs:api": "pnpm exec del-cli docs/src/content/docs/api/reference && tsx ./node_modules/typedoc/bin/typedoc --options typedoc.config.mjs && tsx ./typedoc/postprocess-site-docs.ts",
        "docs:dev": "pnpm run docs:api && astro dev --root docs",
        "docs:build": "pnpm run docs:api && pnpm run docs:build:site",
        "docs:build:site": "astro build --root docs",
        "docs:preview": "astro preview --root docs",
        "verify:docs": "pnpm run docs:api && pnpm run verify:docs:generated",
        "verify:docs:generated": "tsx ./typedoc/verify-docs.ts",
        "prepublish:public": "pnpm run ci",
        "publish:public": "pnpm publish --access public",
        "prepare": "husky"
    },
    "devDependencies": {
        "@astrojs/mdx": "^5.0.3",
        "@astrojs/starlight": "^0.38.3",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@fontsource/ibm-plex-sans": "^5.2.8",
        "@fontsource/jetbrains-mono": "^5.2.8",
        "@fontsource/space-grotesk": "^5.2.10",
        "@types/node": "^25.5.2",
        "@typescript-eslint/eslint-plugin": "^8.58.1",
        "@typescript-eslint/parser": "^8.58.1",
        "@vitest/browser-playwright": "^4.1.4",
        "@vitest/coverage-v8": "^4.1.4",
        "astro": "^6.1.5",
        "del-cli": "^7.0.0",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-only-error": "^1.0.2",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "playwright": "^1.59.1",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typedoc": "^0.28.18",
        "typedoc-plugin-markdown": "^4.11.0",
        "typescript": "^6.0.2",
        "vite": "^8.0.8",
        "vitest": "^4.1.4"
    },
    "engines": {
        "node": ">=24.14.1"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "unrs-resolver"
        ]
    },
    "type": "module",
    "keywords": [
        "cryptography",
        "security",
        "encryption",
        "elgamal",
        "threshold-encryption",
        "public-key-encryption",
        "cryptographic-algorithm",
        "distributed-cryptography",
        "secure-communication",
        "typescript-cryptography",
        "data-protection",
        "privacy",
        "key-management",
        "secret-sharing"
    ]
}
