{
    "name": "threshold-elgamal",
    "version": "2.0.0",
    "description": "A browser-native TypeScript ElGamal library for bigint-based research prototypes, currently shipping core primitives, additive ElGamal, key generation, and serialization helpers.",
    "author": "Piotr Piech <piotr@piech.dev>",
    "license": "MPL-2.0",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "imports": {
        "#root": "./src/index.ts",
        "#core": "./src/core/index.ts",
        "#elgamal": "./src/elgamal/index.ts",
        "#serialize": "./src/serialize/index.ts"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./core": {
            "types": "./dist/core/index.d.ts",
            "import": "./dist/core/index.js"
        },
        "./elgamal": {
            "types": "./dist/elgamal/index.d.ts",
            "import": "./dist/elgamal/index.js"
        },
        "./serialize": {
            "types": "./dist/serialize/index.d.ts",
            "import": "./dist/serialize/index.js"
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Tenemo/threshold-elgamal.git"
    },
    "bugs": {
        "url": "https://github.com/Tenemo/threshold-elgamal/issues"
    },
    "homepage": "https://tenemo.github.io/threshold-elgamal/",
    "packageManager": "pnpm@10.33.0",
    "scripts": {
        "lint": "eslint . -c eslint.config.js",
        "eslint": "pnpm run lint",
        "eslint:fix": "eslint . --fix -c eslint.config.js",
        "typecheck": "tsc",
        "tsc": "pnpm run typecheck",
        "guard:no-math-random": "tsx ./tests/guards/check-no-math-random.ts",
        "check": "pnpm run lint && pnpm run typecheck && pnpm run guard:no-math-random && pnpm run test",
        "prebuild": "pnpm run check && del-cli dist",
        "build": "tsc --project tsconfig.build.json",
        "build:skip": "del-cli dist && tsc --project tsconfig.build.json",
        "test:node": "vitest --project node --run",
        "test:browser": "vitest --project browser --run",
        "test": "pnpm run test:node && pnpm run test:browser",
        "test:watch": "vitest --project node --watch",
        "ci": "pnpm run check && pnpm run build:skip && pnpm run docs:api && pnpm run verify:docs",
        "docs:api": "tsx ./node_modules/typedoc/bin/typedoc --options typedoc.config.mjs",
        "verify:docs": "tsx ./scripts/verify-docs.ts",
        "prepublish:public": "pnpm run ci",
        "publish:public": "pnpm publish --access public",
        "prepare": "husky"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^9.39.4",
        "@types/node": "^25.5.2",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "@vitest/browser-playwright": "^4.1.2",
        "del-cli": "^7.0.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-only-error": "^1.0.2",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "playwright": "^1.59.1",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typedoc": "^0.28.18",
        "typedoc-plugin-markdown": "^4.11.0",
        "typescript": "^6.0.2",
        "vite": "^8.0.3",
        "vitest": "^4.1.2"
    },
    "engines": {
        "node": ">=24.14.1"
    },
    "pnpm": {
        "onlyBuiltDependencies": ["esbuild", "unrs-resolver"]
    },
    "type": "module",
    "keywords": [
        "cryptography",
        "security",
        "encryption",
        "elgamal",
        "threshold-encryption",
        "public-key-encryption",
        "cryptographic-algorithm",
        "distributed-cryptography",
        "secure-communication",
        "typescript-cryptography",
        "data-protection",
        "privacy",
        "key-management",
        "secret-sharing"
    ]
}
